{
  "name": "caipu-admin-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "npm run test:ai-provider-utils && npm run test:dashboard-utils && npm run test:admin-csrf && node tests/ai-provider-component-render.check.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test:ai-provider-utils": "esbuild tests/ai-provider-utils.check.ts --bundle --platform=node --format=esm --alias:@=./src --outfile=/tmp/caipu-admin-ai-provider-utils-test.mjs && node /tmp/caipu-admin-ai-provider-utils-test.mjs",
    "test:dashboard-utils": "esbuild tests/dashboard-distribution.check.ts --bundle --platform=node --format=esm --alias:@=./src --outfile=/tmp/caipu-admin-dashboard-utils-test.mjs && node /tmp/caipu-admin-dashboard-utils-test.mjs",
    "test:admin-csrf": "esbuild tests/admin-csrf.check.ts --bundle --platform=node --format=esm --alias:@=./src --outfile=/tmp/caipu-admin-csrf-test.mjs && node /tmp/caipu-admin-csrf-test.mjs",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "element-plus": "^2.11.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.9.3",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.1.12"
  }
}
