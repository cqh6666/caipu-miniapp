{
  "name": "caipu-miniapp",
  "version": "1.0.0",
  "description": "基于 uni-app 的共享菜谱与美食记录微信小程序，包含 Go 后端和 Vue 3 管理后台。",
  "main": "main.js",
  "scripts": {
    "test": "npm run test:miniapp && npm --prefix admin-web run test",
    "test:miniapp": "esbuild tests/miniapp-frontend.check.ts --bundle --platform=node --format=esm --outfile=/tmp/caipu-miniapp-frontend-test.mjs && node /tmp/caipu-miniapp-frontend-test.mjs",
    "admin:dev": "npm --prefix admin-web run dev",
    "admin:build": "npm --prefix admin-web run build",
    "admin:preview": "npm --prefix admin-web run preview",
    "admin:upload": "bash scripts/upload-admin-web-dist.sh",
    "wx:auto-preview": "bash scripts/wx-auto-preview.sh",
    "wx:auto-preview:skip-compile": "bash scripts/wx-auto-preview.sh --skip-compile"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cqh6666/caipu-miniapp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/cqh6666/caipu-miniapp/issues"
  },
  "homepage": "https://github.com/cqh6666/caipu-miniapp#readme",
  "dependencies": {
    "clipboard": "^2.0.11",
    "dayjs": "^1.11.19",
    "uview-plus": "^3.7.13"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
