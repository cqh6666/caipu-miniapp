APP_NAME=caipu-miniapp-backend
APP_ENV=local
APP_ADDR=:8080
APP_ENV_FILE=

LOG_LEVEL=info

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=

# app settings page access mode: all | admin | whitelist
# APP_ADMIN_OPENIDS / APP_SETTINGS_ALLOWED_OPENIDS use user openid, comma-separated
APP_ADMIN_OPENIDS=
APP_SETTINGS_ACCESS_MODE=all
APP_SETTINGS_ALLOWED_OPENIDS=

JWT_SECRET=replace-me
JWT_EXPIRE_HOURS=720
CREDENTIALS_SECRET=

AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30
AI_FLOWCHART_BASE_URL=
AI_FLOWCHART_API_KEY=
AI_FLOWCHART_MODEL=
AI_FLOWCHART_ENDPOINT_MODE=
AI_FLOWCHART_RESPONSE_FORMAT=
AI_FLOWCHART_TIMEOUT_SECONDS=45
AI_TITLE_ENABLED=false
AI_TITLE_BASE_URL=
AI_TITLE_API_KEY=
AI_TITLE_MODEL=
AI_TITLE_STREAM=false
AI_TITLE_TEMPERATURE=0
AI_TITLE_MAX_TOKENS=64
AI_TITLE_TIMEOUT_SECONDS=3
AI_ALERT_ENABLED=false
AI_ALERT_FAILURE_THRESHOLD=3
AI_ALERT_SMTP_HOST=smtp.qq.com
AI_ALERT_SMTP_PORT=587
AI_ALERT_SMTP_USERNAME=
AI_ALERT_SMTP_PASSWORD=
AI_ALERT_FROM_EMAIL=
AI_ALERT_TO_EMAILS=

DIET_ASSISTANT_AI_BASE_URL=https://api.longcat.chat/openai/v1
DIET_ASSISTANT_AI_API_KEY=
DIET_ASSISTANT_AI_MODEL=LongCat-2.0-Preview
DIET_ASSISTANT_AI_TIMEOUT_SECONDS=90

LINKPARSE_SIDECAR_ENABLED=false
LINKPARSE_SIDECAR_BASE_URL=http://127.0.0.1:8091
LINKPARSE_SIDECAR_TIMEOUT_SECONDS=150
LINKPARSE_SIDECAR_API_KEY=

# 必须和 manifest.json 里的 mp-weixin.appid 保持一致
WECHAT_APP_ID=wxafe7c4144c9c063e
WECHAT_APP_SECRET=

SQLITE_PATH=./data/app.db
SQLITE_BUSY_TIMEOUT_MS=5000
MIGRATION_DIR=./migrations

UPLOAD_DIR=./data/uploads
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_MAX_IMAGE_MB=10

INVITE_DEFAULT_EXPIRE_HOURS=72
INVITE_DEFAULT_MAX_USES=10

RECIPE_AUTO_PARSE_ENABLED=true
RECIPE_AUTO_PARSE_INTERVAL_SECONDS=30
RECIPE_AUTO_PARSE_BATCH_SIZE=3

RECIPE_FLOWCHART_ENABLED=true
RECIPE_FLOWCHART_AUTO_ENQUEUE_ENABLED=false
RECIPE_FLOWCHART_INTERVAL_SECONDS=5
RECIPE_FLOWCHART_BATCH_SIZE=1

RECIPE_IMAGE_MIRROR_ENABLED=true
RECIPE_IMAGE_MIRROR_INTERVAL_SECONDS=180
RECIPE_IMAGE_MIRROR_BATCH_SIZE=2
